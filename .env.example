# Spotify Sync - Environment Configuration
# Copy this file to .env and customize for your environment

# --- Music & Playlist Paths ---
SPM_MUSIC_PATH=/music
SPM_PLAYLISTS_PATH=/playlists
SPM_DB_PATH=/app/data/spm.db

# --- slskd ---
SPM_SLSKD_URL=http://slskd:5030
SPM_SLSKD_API_KEY=

# --- Prowlarr ---
SPM_PROWLARR_URL=http://prowlarr:9696
SPM_PROWLARR_API_KEY=

# --- qBittorrent ---
SPM_QBITTORRENT_URL=http://qbittorrent:8080
SPM_QBITTORRENT_USERNAME=admin
SPM_QBITTORRENT_PASSWORD=adminadmin

# --- Timezone ---
TZ=Europe/Rome

# --- Log level ---
SPM_LOG_LEVEL=INFO